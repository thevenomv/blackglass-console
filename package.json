{
  "name": "blackglass",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "dev:doppler": "doppler run -- npm run dev",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "start:doppler": "doppler run -- npm run start",
    "typecheck": "tsc --noEmit",
    "doppler:verify": "node scripts/doppler-verify.mjs",
    "verify:staging": "node scripts/verify-staging.mjs",
    "verify:stage0": "npm run lint && npm run check:openapi && npm run schemas:export && git diff --exit-code openapi/zod-schemas.json && npm run typecheck && npm run test:unit && npm run build",
    "do:apply-stage0": "node scripts/run-do-apply-stage0.mjs",
    "stripe:setup": "node scripts/stripe-setup.mjs",
    "lint": "eslint .",
    "check:openapi": "node scripts/check-openapi-paths.mjs",
    "schemas:export": "tsx scripts/export-zod-schemas.ts",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test tests/e2e/live-ssr.spec.ts",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@sentry/nextjs": "^10.51.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ssh2": "^1.17.0",
    "stripe": "^22.1.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.52.0",
    "@tanstack/react-virtual": "^3.13.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5",
    "zod-to-json-schema": "^3.25.2"
  }
}
