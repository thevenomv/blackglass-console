{
  "name": "blackglass",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "dev:doppler": "doppler run -- npm run dev",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "start:doppler": "doppler run -- npm run start",
    "typecheck": "tsc --noEmit",
    "cf:audit-edge": "node scripts/verify/cloudflare-edge-audit.mjs",
    "cf:public-seo-check": "node scripts/verify/cf-public-seo-check.mjs",
    "doppler:verify": "node scripts/secrets/doppler-verify.mjs",
    "verify:staging": "node scripts/verify/verify-staging.mjs",
    "verify:fast": "npm run lint && npm run typecheck && npm run test:unit",
    "verify:contract": "npm run check:rls-bypass && npm run check:openapi && npm run schemas:export && git diff --exit-code openapi/zod-schemas.json && npm run db:migrate:files",
    "verify:build": "npm run build",
    "verify:stage0": "npm run verify:fast && npm run verify:contract && npm run verify:build",
    "verify:release": "npm run verify:stage0 && npm run build:worker",
    "verify:stage0:clean": "npm run clean:next && npm run verify:stage0",
    "clean:next": "node scripts/build/clean-next.mjs",
    "build:optimize-og": "node scripts/build/optimize-og-images.mjs",
    "do:apply-stage0": "node scripts/do/run-do-apply-stage0.mjs",
    "stripe:setup": "node scripts/stripe/stripe-setup.mjs",
    "audit:export-spaces": "node scripts/audit/export-audit-spaces.mjs",
    "audit:verify-jsonl": "node scripts/audit/verify-audit-jsonl-integrity.mjs",
    "fuzz:ingest": "node scripts/load/fuzz-ingest-validate.mjs",
    "load:rate-local": "node scripts/load/rate-limit-burst-local.mjs",
    "pen-test:smoke": "node scripts/verify/pen-test-smoke.mjs",
    "sbom": "npx --yes @cyclonedx/cyclonedx-npm --output-file cyclonedx-sbom.json",
    "blackglassctl": "node scripts/cli/blackglassctl.mjs",
    "env:check": "tsx scripts/verify/validate-env.ts",
    "email:test": "node scripts/email/send-test-emails.mjs",
    "email:marketing": "node scripts/email/send-opt-in-marketing.mjs",
    "email:preview-sequences": "node scripts/apollo/send-sequence-previews.mjs",
    "prospects:pull": "node scripts/apollo/apollo-prospect-pull.mjs",
    "prospects:search": "node scripts/apollo/apollo-prospect-search.mjs",
    "prospects:enrol": "node scripts/apollo/apollo-enrol-sequences.mjs",
    "prospects:stats": "node scripts/apollo/apollo-sequence-stats.mjs",
    "secrets:init-local": "node scripts/secrets/init-local-credentials.mjs",
    "secrets:merge-local": "node scripts/secrets/merge-local-secrets.mjs",
    "secrets:verify": "node scripts/secrets/verify-outbound-keys.mjs",
    "ops:selfcheck": "node scripts/verify/ops-automation-selfcheck.mjs",
    "prune:webhooks": "node scripts/webhooks/prune-webhook-idempotency.mjs",
    "reconcile:billing": "node scripts/stripe/reconcile-saas-billing.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/ops/apply-migrations.mjs",
    "db:migrate:check": "node scripts/ops/apply-migrations.mjs --check",
    "db:migrate:status": "node scripts/ops/apply-migrations.mjs --status",
    "db:migrate:files": "node scripts/ops/check-migration-files.mjs",
    "db:migrate:008": "node scripts/db/run-migration-008.mjs",
    "db:backup": "node scripts/ops/backup-postgres.mjs",
    "do:mothball": "pwsh scripts/do/mothball-databases.ps1",
    "do:rebuild": "pwsh scripts/do/rebuild-databases.ps1",
    "lint": "eslint .",
    "check:rls-bypass": "node scripts/build/check-rls-bypass-tags.mjs",
    "check:openapi": "node scripts/build/check-openapi-paths.mjs",
    "openapi:types": "openapi-typescript openapi/blackglass.yaml -o src/types/openapi.d.ts --export-type",
    "schemas:export": "tsx scripts/build/export-zod-schemas.ts",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --grep-invert @pixel",
    "test:e2e:all": "playwright test",
    "test:e2e:theme": "playwright test tests/e2e/theme-tokens.spec.ts",
    "test:e2e:visual": "playwright test --grep @pixel",
    "test:e2e:live": "playwright test tests/e2e/live-ssr.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "worker": "tsx src/worker/scan/index.ts",
    "worker:doppler": "doppler run -- tsx src/worker/scan/index.ts",
    "worker:ops": "tsx src/worker/ops/index.ts",
    "worker:ops:doppler": "doppler run -- tsx src/worker/ops/index.ts",
    "build:worker": "node scripts/build/build-worker.mjs",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1045.0",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1044.0",
    "@clerk/nextjs": "^7.3.0",
    "@sentry/nextjs": "^10.51.0",
    "@tanstack/react-virtual": "^3.13.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.5",
    "autoprefixer": "^10.4.20",
    "bullmq": "^5.76.5",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "^9.15.1",
    "ioredis": "^5.10.1",
    "next": "^16.2.4",
    "pdf-lib": "^1.17.1",
    "pg": "^8.15.0",
    "postcss": "^8.5.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.14.0",
    "ssh2": "^1.17.0",
    "stripe": "^22.1.0",
    "svix": "^1.92.2",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.52.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-import": "^2.32.0",
    "openapi-typescript": "^7.10.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5",
    "zod-to-json-schema": "^3.25.2"
  }
}
