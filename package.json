{
  "name": "blackglass",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "dev:doppler": "doppler run -- npm run dev",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "start:doppler": "doppler run -- npm run start",
    "typecheck": "tsc --noEmit",
    "doppler:verify": "node scripts/doppler-verify.mjs",
    "verify:staging": "node scripts/verify-staging.mjs",
    "verify:stage0": "npm run lint && npm run check:openapi && npm run schemas:export && git diff --exit-code openapi/zod-schemas.json && npm run typecheck && npm run test:unit && npm run build",
    "verify:release": "npm run verify:stage0 && npm run build:worker",
    "verify:stage0:clean": "npm run clean:next && npm run verify:stage0",
    "clean:next": "node scripts/clean-next.mjs",
    "do:apply-stage0": "node scripts/run-do-apply-stage0.mjs",
    "stripe:setup": "node scripts/stripe-setup.mjs",
    "audit:export-spaces": "node scripts/export-audit-spaces.mjs",
    "audit:verify-jsonl": "node scripts/verify-audit-jsonl-integrity.mjs",
    "fuzz:ingest": "node scripts/fuzz-ingest-validate.mjs",
    "load:rate-local": "node scripts/rate-limit-burst-local.mjs",
    "pen-test:smoke": "node scripts/pen-test-smoke.mjs",
    "sbom": "npx --yes @cyclonedx/cyclonedx-npm --output-file cyclonedx-sbom.json",
    "blackglassctl": "node scripts/blackglassctl.mjs",
    "env:check": "tsx scripts/validate-env.ts",
    "prune:webhooks": "node scripts/prune-webhook-idempotency.mjs",
    "reconcile:billing": "node scripts/reconcile-saas-billing.mjs",
    "db:generate": "drizzle-kit generate",
    "lint": "eslint .",
    "check:openapi": "node scripts/check-openapi-paths.mjs",
    "openapi:types": "openapi-typescript openapi/blackglass.yaml -o src/types/openapi.d.ts --export-type",
    "schemas:export": "tsx scripts/export-zod-schemas.ts",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --grep-invert @pixel",
    "test:e2e:all": "playwright test",
    "test:e2e:theme": "playwright test tests/e2e/theme-tokens.spec.ts",
    "test:e2e:visual": "playwright test --grep @pixel",
    "test:e2e:live": "playwright test tests/e2e/live-ssr.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "worker": "tsx src/worker/scan-worker.ts",
    "worker:doppler": "doppler run -- tsx src/worker/scan-worker.ts",
    "build:worker": "node scripts/build-worker.mjs",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@clerk/nextjs": "^7.3.0",
    "@sentry/nextjs": "^10.51.0",
    "@tanstack/react-virtual": "^3.13.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.5",
    "autoprefixer": "^10.4.20",
    "bullmq": "^5.76.5",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "next": "^16.2.4",
    "pg": "^8.15.0",
    "postcss": "^8.5.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ssh2": "^1.17.0",
    "stripe": "^22.1.0",
    "svix": "^1.92.2",
    "tailwindcss": "^3.4.16",
    "typescript": "^6.0.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.52.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.4",
    "openapi-typescript": "^7.10.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5",
    "zod-to-json-schema": "^3.25.2"
  }
}
