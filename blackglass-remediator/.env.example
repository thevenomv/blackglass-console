# Environment configuration for blackglass-remediator
# Copy to .env and fill in values.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development            # development | staging | production
PORT=8080
DEBUG=false
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# HMAC-SHA256 secret for verifying incoming BLACKGLASS webhooks.
# Must match WEBHOOK_SECRET in BLACKGLASS env vars.
BLACKGLASS_WEBHOOK_SECRET=

# Internal service-to-service API key (for direct API calls to this service).
API_SECRET_KEY=change-me-in-production

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://remediator:remediator@localhost:5432/remediator
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# ---------------------------------------------------------------------------
# Redis (optional — for future async task orchestration)
# ---------------------------------------------------------------------------
REDIS_URL=

# ---------------------------------------------------------------------------
# LLM / Agent configuration
# ---------------------------------------------------------------------------
# Local-first by default. Set LLM_PROVIDER=openai or anthropic for cloud models.
LLM_PROVIDER=ollama            # ollama | openai | anthropic
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b       # Any Ollama-compatible model

# Temperature (0.0-1.0 — keep low for determinism)
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=3

# Optional cloud provider API keys (only needed if LLM_PROVIDER != ollama)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# DigitalOcean (sandbox verification)
# ---------------------------------------------------------------------------
DIGITALOCEAN_TOKEN=
DO_REGION=nyc3
DEFAULT_SANDBOX_IMAGE=ubuntu-22-04-x64
DEFAULT_SANDBOX_SIZE=s-1vcpu-1gb
SANDBOX_TTL_HOURS=2

# Set to true to enable live sandbox verification via DO droplets.
# Keep false in development to skip sandbox and move directly to AWAITING_APPROVAL.
ENABLE_SANDBOX_VERIFICATION=false

# ---------------------------------------------------------------------------
# BLACKGLASS integration
# ---------------------------------------------------------------------------
BLACKGLASS_API_BASE_URL=http://localhost:3000
BLACKGLASS_API_TOKEN=

# ---------------------------------------------------------------------------
# Remediator behaviour
# ---------------------------------------------------------------------------
MAX_REMEDIATION_COMMANDS=10
RECOMMENDATION_EXPIRY_HOURS=72

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
SENTRY_DSN=
OTEL_ENDPOINT=                 # e.g. http://localhost:4317 for OTLP gRPC
