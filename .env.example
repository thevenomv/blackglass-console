# Copy to `.env.local` for local overrides.

# --- API ---
# true (default): mock payloads + demo KPI deltas when no collector is configured.
# If COLLECTOR_HOST_1 + SSH_PRIVATE_KEY are set, / and /hosts still use live inventory over SSR.
# false: SSR uses NEXT_PUBLIC_APP_URL/api/v1/* for fleet + hosts (production-style).
NEXT_PUBLIC_USE_MOCK=true
NEXT_PUBLIC_API_URL=
# Required for server-side fetches to same-origin /api/v1 when USE_MOCK=false (CI, Docker, prod).
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# --- Auth (console gate) ---
AUTH_REQUIRED=false
# When AUTH_REQUIRED=true in production, set a long random secret (not the dev default).
# AUTH_SESSION_SECRET=

# --- Secrets: Doppler (JIT fetch at scan time) ---
# SECRET_PROVIDER=doppler
# DOPPLER_PROJECT=blackglass
# DOPPLER_CONFIG=dev
# DOPPLER_TOKEN=dp.st.…   # required in Docker/DO unless secrets are synced as plain env; optional for local `doppler run` (CLI auth)
# Optional: BLACKGLASS_SSH_SECRET_NAME=SSH_PRIVATE_KEY
#
# Local: install Doppler CLI (https://docs.doppler.com/docs/install-cli) then:
#   npm run dev:doppler
# Or set the vars above in `.env.local` and run:
#   node --env-file=.env.local scripts/doppler-verify.mjs
#   npm run dev

# --- Collector (live SSH mode) ---
# When COLLECTOR_HOST_1 and credential source are set, the app collects real host telemetry.
# With SECRET_PROVIDER=env, set SSH_PRIVATE_KEY below. With doppler/infisical/vault, set that provider.
# Optional COLLECTOR_HOST_2, COLLECTOR_HOST_3, … must be consecutive (no gaps).
# COLLECTOR_HOST_1=165.227.229.48
# COLLECTOR_HOST_1_NAME=prod-web-01
# COLLECTOR_USER=blackglass
# SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"

# --- Baseline persistence (production) ---
# When set, baselines are saved to this JSON file and survive restarts (mount a volume in Docker/DO).
# BASELINE_STORE_PATH=/data/blackglass/baselines.json

# --- Drift history (optional) ---
# If unset, drift day stamps stay in process memory only.
# DRIFT_HISTORY_PATH=/data/blackglass/drift-history.json

# --- Docker / Node ---
NODE_ENV=production

# --- DigitalOcean App Platform (Git-based) ---
# Set NEXT_PUBLIC_APP_URL to the deployed HTTPS URL (RUN_AND_BUILD_TIME in DO).
# Spec templates: .do/app-git.production.yaml, .do/app-git.staging.yaml
