{
  "spec": {
    "name": "blackglass",
    "region": "lon",
    "alerts": [{ "rule": "DEPLOYMENT_FAILED" }],
    "ingress": {
      "rules": [
        {
          "match": { "path": { "prefix": "/" } },
          "component": { "name": "web" }
        }
      ]
    },
    "services": [
      {
        "name": "web",
        "github": {
          "repo": "thevenomv/blackglass-console",
          "branch": "main",
          "deploy_on_push": true
        },
        "environment_slug": "node-js",
        "instance_count": 1,
        "instance_size_slug": "basic-xxs",
        "http_port": 3000,
        "source_dir": "/",
        "build_command": "npm ci && npm run build",
        "run_command": "npm run start",
        "health_check": {
          "http_path": "/api/health",
          "port": 3000,
          "initial_delay_seconds": 60,
          "period_seconds": 10,
          "timeout_seconds": 5,
          "success_threshold": 1,
          "failure_threshold": 6
        },
        "envs": [
          {
            "key": "NODE_ENV",
            "value": "production",
            "scope": "RUN_AND_BUILD_TIME"
          },
          {
            "key": "NEXT_PUBLIC_APP_URL",
            "value": "http://127.0.0.1:3000",
            "scope": "RUN_AND_BUILD_TIME"
          },
          {
            "key": "NEXT_PUBLIC_USE_MOCK",
            "value": "true",
            "scope": "RUN_AND_BUILD_TIME"
          },
          {
            "key": "NEXT_PUBLIC_API_URL",
            "value": "",
            "scope": "RUN_AND_BUILD_TIME"
          },
          { "key": "AUTH_REQUIRED", "value": "false", "scope": "RUN_TIME" }
        ]
      }
    ]
  }
}
