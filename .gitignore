.env*.local

.vercel

# Local snapshots / API payloads pulled via the DO API for one-off ops
.do/app-current.json
.do/app-update-payload.json

# Local-only operator artefacts: rotated passphrases, scratch one-off scripts,
# per-host ingest keys (.lab-*.local), prospect CSVs with PII, and anything
# else you do NOT want in source control. Convention: any file under /.local/
# stays on the operator's machine.
/.local/

# Prospect / outreach CSVs — may contain PII. Keep them out of source control.
prospects-*.csv

# Python
__pycache__/
*.py[cod]
*$py.class

# IDE
.idea
.vscode

# Sentry Config File
.env.sentry-build-plugin

# Scratch commit-message temp files used by the agent when piping
# multi-line messages on PowerShell (which can't handle bash heredocs).
.git-commit-msg.tmp

# Terraform
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
crash.log
override.tf
override.tf.json

# Mothball / ops artefacts — contain cluster IDs and backup references; store in 1Password
scripts/do/mothball-config.json
backups/
