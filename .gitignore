/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# Testing
/coverage
/playwright-report/
/test-results/
/tests/e2e/.auth/

# Next.js
/.next/
/out/

# Worker bundle output (esbuild)
/dist/


# Misc
.DS_Store
cyclonedx-sbom.json
*.pem
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Debug / temp artifacts
build*.log
build2.log
migration-output.txt

# Env
.env*.local

.vercel

# Local snapshots / API payloads pulled via the DO API for one-off ops
.do/app-current.json
.do/app-update-payload.json
# One-off secrets generated for lab installs (per-host ingest keys, etc.)
.lab-bg-key.local
.lab-host-keys.local

# Local-only operator artefacts (rotated passphrases, scratch one-off scripts,
# anything you do NOT want in source control). Convention: any file under
# /.local/ stays on the operator's machine.
/.local/

# Python
__pycache__/
*.py[cod]
*$py.class

# IDE
.idea
.vscode

# Sentry Config File
.env.sentry-build-plugin

# Scratch commit-message temp files used by the agent when piping
# multi-line messages on PowerShell (which can't handle bash heredocs).
.git-commit-msg.tmp

# Terraform
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
